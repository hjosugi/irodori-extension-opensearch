{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.opensearch",
  "name": "OpenSearch Connector",
  "version": "0.1.4",
  "publisher": "irodori",
  "description": "OpenSearch Connector contributes the OpenSearch database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-opensearch",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "openSearch.connector",
        "engine": "openSearch",
        "label": "OpenSearch",
        "aliases": [
          "openSearch",
          "open-search",
          "OpenSearch"
        ],
        "defaultPort": 9200,
        "wire": "search",
        "module": "openSearch.driver",
        "features": [
          "metadata",
          "vectorSearch",
          "embeddingSearch",
          "hybridSearch",
          "queryTemplates",
          "visualization",
          "fullTextSearch",
          "facetedSearch"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "openSearch",
            "wire": "search",
            "port": 9200,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 9200,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 9200
              },
              {
                "id": "database",
                "label": "Database",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 9200
            },
            {
              "id": "database",
              "label": "Database",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "basic",
              "label": "Basic authentication",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "apiKey",
              "label": "API key",
              "kind": "apiKey",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "apiKey",
                  "label": "API key",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "bearerToken",
              "label": "Bearer token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "jwt",
              "label": "JWT bearer token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "accessToken",
              "label": "Access token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "oauth2",
              "label": "OAuth 2.0",
              "kind": "oauth2",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "accessToken",
                  "label": "Access token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "refreshToken",
                  "label": "Refresh token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "clientId",
                  "label": "Client ID",
                  "type": "string"
                },
                {
                  "id": "clientSecret",
                  "label": "Client secret",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "clientCertificate",
              "label": "Client certificate / mTLS",
              "kind": "certificate",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "clientCertificate",
                  "label": "Client certificate",
                  "type": "pem"
                },
                {
                  "id": "clientPrivateKey",
                  "label": "Client private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "clientPrivateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "awsDefaultCredentialsChain",
              "label": "AWS default credential chain",
              "kind": "iam",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "awsSigV4",
              "label": "AWS SigV4",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "accessKeyId",
                  "label": "Access key ID",
                  "type": "string"
                },
                {
                  "id": "secretAccessKey",
                  "label": "Secret access key",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "sessionToken",
                  "label": "Session token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "awsProfile",
              "label": "AWS shared config profile",
              "kind": "iam",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "profile",
                  "label": "Profile",
                  "type": "string",
                  "option": "awsProfile"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "awsSso",
              "label": "AWS IAM Identity Center / SSO",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "ssoSession",
                  "label": "SSO session",
                  "type": "string",
                  "option": "ssoSession"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "webIdentity",
              "label": "AWS web identity",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "roleArn",
                  "label": "Role ARN",
                  "type": "string",
                  "option": "roleArn"
                },
                {
                  "id": "webIdentityToken",
                  "label": "Web identity token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "awsAssumeRole",
              "label": "AWS STS assume role",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "roleArn",
                  "label": "Role ARN",
                  "type": "string",
                  "option": "roleArn",
                  "required": true
                },
                {
                  "id": "externalId",
                  "label": "External ID",
                  "type": "string",
                  "option": "externalId"
                },
                {
                  "id": "sessionName",
                  "label": "Session name",
                  "type": "string",
                  "option": "sessionName"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "token",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": false,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "search",
            "openSearch"
          ],
          "customDriverOptions": true
        },
        "experience": {
          "schemaVersion": 1,
          "domains": [
            "search",
            "vector"
          ],
          "inspiredBy": [
            "OpenSearch Dashboards Discover",
            "OpenSearch aggregations",
            "OpenSearch hybrid search",
            "OpenSearch k-NN search"
          ],
          "resultViews": [
            "searchHits",
            "facets",
            "json",
            "table",
            "vectorNeighbors"
          ],
          "objectTypes": [
            "indexes",
            "mappings",
            "aliases",
            "templates",
            "analyzers",
            "collections",
            "vectors",
            "payloadFields",
            "partitions",
            "namespaces"
          ],
          "workflows": [
            {
              "id": "search-discover",
              "label": "Discover documents",
              "description": "Search documents with query text, field filters, and highlights.",
              "resultView": "searchHits",
              "templateIds": [
                "search-query-string"
              ]
            },
            {
              "id": "search-facets",
              "label": "Facet breakdown",
              "description": "Build terms and date facets for a filtered result set.",
              "resultView": "facets",
              "templateIds": [
                "search-facets"
              ]
            },
            {
              "id": "search-hybrid",
              "label": "Hybrid search",
              "description": "Blend text relevance with vector nearest-neighbor search.",
              "resultView": "searchHits",
              "templateIds": [
                "search-hybrid"
              ]
            },
            {
              "id": "vector-similarity-search",
              "label": "Similarity search",
              "description": "Search nearest neighbors from a pasted vector or embedding variable.",
              "resultView": "vectorNeighbors",
              "templateIds": [
                "vector-similarity"
              ]
            },
            {
              "id": "vector-filtered-search",
              "label": "Filtered ANN search",
              "description": "Combine vector similarity with metadata or scalar filters.",
              "resultView": "vectorNeighbors",
              "templateIds": [
                "vector-filtered"
              ]
            },
            {
              "id": "vector-health",
              "label": "Collection or index health",
              "description": "Inspect vector count, dimensionality, metric, shard, and index status.",
              "resultView": "table",
              "templateIds": [
                "vector-health"
              ]
            }
          ],
          "queryTemplates": [
            {
              "id": "search-query-string",
              "label": "Query string search",
              "language": "json",
              "description": "Search all mapped fields and highlight matched text.",
              "insertText": "{\n  \"query\": {\n    \"query_string\": {\n      \"query\": \"$query\"\n    }\n  },\n  \"highlight\": {\n    \"fields\": { \"*\": {} }\n  },\n  \"size\": 25\n}",
              "parameters": [
                {
                  "id": "query",
                  "label": "Search query",
                  "type": "string"
                }
              ],
              "resultView": "searchHits"
            },
            {
              "id": "search-facets",
              "label": "Terms facet",
              "language": "json",
              "description": "Return a terms aggregation for a field.",
              "insertText": "{\n  \"size\": 0,\n  \"aggs\": {\n    \"by_field\": {\n      \"terms\": { \"field\": \"$field\", \"size\": 20 }\n    }\n  }\n}",
              "parameters": [
                {
                  "id": "field",
                  "label": "Facet field",
                  "type": "string"
                }
              ],
              "resultView": "facets"
            },
            {
              "id": "search-hybrid",
              "label": "Hybrid text and vector search",
              "language": "json",
              "description": "Keep a starter shape for combining text relevance with vector search.",
              "insertText": "{\n  \"query\": {\n    \"bool\": {\n      \"must\": [\n        { \"match\": { \"$textField\": \"$query\" } }\n      ]\n    }\n  },\n  \"knn\": {\n    \"field\": \"embedding\",\n    \"query_vector\": $vector,\n    \"k\": 10,\n    \"num_candidates\": 100\n  }\n}",
              "parameters": [
                {
                  "id": "textField",
                  "label": "Text field",
                  "type": "string"
                },
                {
                  "id": "query",
                  "label": "Search query",
                  "type": "string"
                },
                {
                  "id": "vector",
                  "label": "Query vector",
                  "type": "json"
                }
              ],
              "resultView": "searchHits"
            },
            {
              "id": "vector-similarity",
              "label": "kNN vector search",
              "language": "json",
              "description": "Search nearest vectors using a dense-vector field.",
              "insertText": "{\n  \"knn\": {\n    \"field\": \"embedding\",\n    \"query_vector\": $vector,\n    \"k\": 10,\n    \"num_candidates\": 100\n  }\n}",
              "parameters": [
                {
                  "id": "vector",
                  "label": "Query vector",
                  "type": "json"
                }
              ],
              "resultView": "vectorNeighbors"
            },
            {
              "id": "vector-filtered",
              "label": "Filtered kNN search",
              "language": "json",
              "description": "Combine kNN search with a metadata filter.",
              "insertText": "{\n  \"knn\": {\n    \"field\": \"embedding\",\n    \"query_vector\": $vector,\n    \"k\": 10,\n    \"num_candidates\": 100,\n    \"filter\": { \"term\": { \"$field\": \"$value\" } }\n  }\n}",
              "parameters": [
                {
                  "id": "vector",
                  "label": "Query vector",
                  "type": "json"
                },
                {
                  "id": "field",
                  "label": "Filter field",
                  "type": "string"
                },
                {
                  "id": "value",
                  "label": "Filter value",
                  "type": "string"
                }
              ],
              "resultView": "vectorNeighbors"
            },
            {
              "id": "vector-health",
              "label": "Index mapping",
              "language": "text",
              "description": "Inspect vector mapping and index settings.",
              "insertText": "GET /$index/_mapping",
              "parameters": [
                {
                  "id": "index",
                  "label": "Index",
                  "type": "string"
                }
              ],
              "resultView": "json"
            }
          ],
          "inspectorHints": [
            {
              "id": "search-mapping",
              "label": "Mapping inspector",
              "description": "Show analyzer, type, and fielddata/doc_values availability per field."
            },
            {
              "id": "search-facetable",
              "label": "Facet suggestions",
              "description": "Suggest keyword, numeric, boolean, and date fields for facets."
            },
            {
              "id": "vector-dimension",
              "label": "Dimension badge",
              "description": "Surface vector dimension and distance metric beside each collection or index."
            },
            {
              "id": "vector-payload",
              "label": "Payload fields",
              "description": "Show filterable metadata fields before composing a filtered search."
            }
          ]
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "openSearch.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
